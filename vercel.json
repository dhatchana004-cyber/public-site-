{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://api.vinobrowsing.com/api/$1"
    },
    {
      "source": "/media/(.*)",
      "destination": "https://api.vinobrowsing.com/media/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
